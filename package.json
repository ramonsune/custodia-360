{
  "name": "custodia360",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 8080",
    "build": "next build",
    "build:production": "node scripts/validate-env.js && SKIP_TYPE_CHECK=true DISABLE_ESLINT=true next build",
    "build:static": "node scripts/validate-env.js && SKIP_TYPE_CHECK=true DISABLE_ESLINT=true next build && next export",
    "build:netlify": "npm install --legacy-peer-deps && npm run build:production",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "validate-env": "node scripts/validate-env.js",
    "postinstall": "node -e \"console.log('Dependencies installed successfully')\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/supabase-js": "^2.57.4",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.540.0",
    "next": "^15.5.0",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "resend": "^6.0.1",
    "same-runtime": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.13.4",
    "@types/jspdf": "^2.0.0",
    "dotenv": "^17.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.0"
  },
  "overrides": {
    "puppeteer": {
      "ws": "^8.18.0"
    }
  }
}
