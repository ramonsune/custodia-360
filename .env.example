# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend Configuration (PRINCIPAL)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@your-domain.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Database Configuration (opcional si usas Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/custodia360

# JWT Secret (para autenticación personalizada)
JWT_SECRET=your_jwt_secret_key

# Email Configuration (LEGACY - usar Resend en su lugar)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Environment
NODE_ENV=development

# Configuración específica de LOPIVI
LOPIVI_API_URL=https://api.lopivi.es
LOPIVI_API_KEY=your_lopivi_api_key

# URLs de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Configuración de subida de archivos
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png
